# ─────────────────────────────────────────────────────────────────────────────
# TxGen Platform — Environment Variables
#
# Copy this file to .env and fill in real values.
# The .env file is gitignored. This .env.example is committed.
#
# IMPORTANT: Two URL patterns exist in this system:
#   KEYCLOAK_URL  → container-to-container (FastAPI → Keycloak inside Docker)
#   VITE_*        → browser-to-host URLs (React runs in the user's browser)
#
# React has NO Keycloak URL — it only calls FastAPI.
# ─────────────────────────────────────────────────────────────────────────────

# ── Keycloak (used only by FastAPI services — never by React) ─────────────────

# The confidential client secret generated in the Keycloak admin UI.
# Clients → txgen-backend → Credentials → Client secret
KEYCLOAK_CLIENT_SECRET=change-me-in-keycloak-admin

# ── Database URLs (used by Python services — container-to-container) ──────────

# All DB credentials match the Docker Compose environment blocks above.
# Only change these if you modify the Compose service definitions.
MONGO_URL=mongodb://txgen:txgen@mongodb:27017/banking_db
DATABASE_URL=postgresql+asyncpg://txgen:txgen@timescaledb:5432/txgen
REDIS_URL=redis://redis:6379
KAFKA_BROKERS=kafka:29092

# ── CORS (controls which browser origins FastAPI accepts requests from) ────────

# In development this is the Vite dev server.
# In production set this to your actual frontend domain.
CORS_ORIGINS=http://localhost:5173

# ── React build-time variables (VITE_ prefix makes them available in browser) ──

# These are the ONLY external URLs React knows about.
# Keycloak is NOT listed here — that is intentional.
VITE_ACCOUNT_API_URL=http://localhost:8001
VITE_TXGEN_API_URL=http://localhost:8002
